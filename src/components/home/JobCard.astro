---
import type { Job } from '@ptypes/index'

interface Props {
  job: Job
}

const { job } = Astro.props
---

<article class="job" data-reveal>
  <div class="job__inner">
    {job.logo && (
      <figure class="job__logo">
        <img
          src={job.logo}
          alt={`Logo de ${job.company}`}
          width="48"
          height="48"
          loading="lazy"
        />
      </figure>
    )}
    <div class="job__body">
      <div class="job__header">
        <div class="job__meta">
          <h3 class="job__title">{job.title}</h3>
          <p class="job__company">{job.company}</p>
        </div>
        <span class="job__period">{job.period}</span>
      </div>
    </div>
  </div>
</article>

<style>
  .job {
    background: var(--surface-1);
    border: var(--card-border);
    border-radius: var(--radius-lg);
    padding: 1.6rem 2rem;
    box-shadow: var(--shadow-soft);
    transition:
      transform var(--transition-fast),
      border-color var(--transition-fast),
      box-shadow var(--transition-fast);
  }

  .job:hover {
    transform: translateY(-1px);
    border-color: rgba(211, 115, 78, 0.2);
    box-shadow: var(--shadow-medium);
  }

  .job__inner {
    display: flex;
    align-items: flex-start;
    gap: 1.4rem;
  }

  .job__logo {
    flex: none;
    width: 4.8rem;
    height: 4.8rem;
    border-radius: var(--radius-md);
    overflow: hidden;
    background: var(--surface-2);
    border: var(--border-subtle);
  }

  .job__logo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .job__body {
    flex: 1;
    min-width: 0;
  }

  .job__header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1rem;
  }

  .job__meta {
    flex: 1;
    min-width: 0;
  }

  .job__title {
    font-weight: 600;
    font-size: 1.6rem;
    color: var(--title-color);
    line-height: 1.3;
  }

  .job__company {
    font-size: 1.4rem;
    color: var(--text-muted);
    margin-block-start: 0.3rem;
    text-wrap: pretty;
  }

  .job__period {
    font-size: 1.2rem;
    font-weight: 500;
    color: var(--text-muted);
    background: var(--surface-2);
    padding: 0.3rem 0.9rem;
    border-radius: var(--radius-pill);
    border: var(--border-subtle);
    white-space: nowrap;
    flex: none;
    align-self: flex-start;
  }
</style>
