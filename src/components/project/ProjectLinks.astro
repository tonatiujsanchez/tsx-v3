---
interface Props {
  github?: string
  live?: string
}

const { github, live } = Astro.props
---

{(github || live) && (
  <div class="project-links">
    {github && (
      <a
        class="project-links__link project-links__link--github"
        href={github}
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Ver código fuente en GitHub"
      >
        <i class="bx bxl-github project-links__icon" aria-hidden="true"></i>
        <span>Código fuente</span>
      </a>
    )}
    {live && (
      <a
        class="project-links__link project-links__link--live"
        href={live}
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Ver demo en vivo"
      >
        <i class="bx bx-link-external project-links__icon" aria-hidden="true"></i>
        <span>Ver demo</span>
      </a>
    )}
  </div>
)}

<style>
  .project-links {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .project-links__link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.6rem 1.2rem;
    border-radius: 0.375rem;
    text-decoration: none;
    font-weight: 500;
    font-size: 0.95rem;
    transition: opacity 0.2s ease;
  }

  .project-links__link:hover {
    opacity: 0.8;
  }

  .project-links__link--github {
    background-color: var(--github-color);
    color: #fff;
  }

  .project-links__link--live {
    background-color: var(--black-primary-color);
    color: #fff;
    border: var(--border-primary);
  }

  .project-links__icon {
    font-size: 1.2rem;
  }
</style>
