---
import { socialLinks } from '@data/site'
import ContactForm from '@components/home/ContactForm.astro'
import SocialLink from '@components/ui/SocialLink.astro'
---

<section class="contact-section section" id="contacto">
  <div class="container">
    <h2 class="section__title" data-reveal>Contacto</h2>
    <p class="section__description" data-reveal data-reveal-delay="1">Actualmente estoy disponible para asumir nuevos proyectos, así que siéntete libre de escribirme sobre cualquier idea que quieras contarme.</p>

    <div class="contact" data-reveal data-reveal-delay="2">
      <div class="contact__social">
        {socialLinks.map((link) => (
          <SocialLink
            href={link.href}
            label={link.label}
            icon={link.icon}
          />
        ))}
      </div>

      <ContactForm />
    </div>
  </div>
</section>

<style>
  .contact {
    display: flex;
    flex-direction: column;
    gap: 3.5rem;
    padding-block-start: 3rem;
    max-width: 60rem;
  }

  .contact__social {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.8rem;
  }

  .contact__social :global(.social-link) {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-block: 1.2rem;
    padding-inline: 1.6rem;
    background: var(--surface-1);
    border: var(--card-border);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-soft);
    transition:
      transform var(--transition-fast),
      box-shadow var(--transition-fast),
      border-color var(--transition-fast),
      color var(--transition-fast);
    color: var(--text-color);
  }

  .contact__social :global(.social-link):hover {
    transform: translateY(-1px);
    border-color: rgba(211, 115, 78, 0.25);
    box-shadow: var(--shadow-glow);
    color: var(--title-color);
  }

  .contact__social :global(.social-link__icon) {
    font-size: 1.8rem;
  }

  .contact__social :global(.social-link__label) {
    font-size: 1.4rem;
    font-weight: 500;
  }

  .contact__social :global(.social-link__arrow) {
    font-size: 1.6rem;
    transition: transform var(--transition-fast);
  }

  .contact__social :global(.social-link:hover .social-link__arrow) {
    transform: translateX(3px);
  }
</style>
