---
import { getCollection } from 'astro:content'
import ProjectCard from '@components/home/ProjectCard.astro'

const projects = (await getCollection('projects')).sort(
  (a, b) => a.data.order - b.data.order
)
---

<section class="projects" id="proyectos">
  <div class="projects__container">
    <h2 class="projects__title">Proyectos</h2>
    <div class="projects__list">
      {projects.map((project) => (
        <ProjectCard
          title={project.data.title}
          slug={project.id}
          year={project.data.year ?? new Date().getFullYear()}
          summary={project.data.description}
          thumbnail={{
            full: project.data.cover,
            md: project.data.cover.replace('.webp', '-543.webp'),
            sm: project.data.cover.replace('.webp', '-380.webp'),
          }}
        />
      ))}
    </div>
  </div>
</section>

