---
import { getCollection } from 'astro:content'
import ProjectCard from '@components/home/ProjectCard.astro'

const projects = (await getCollection('projects')).sort(
  (a, b) => a.data.order - b.data.order
)
---

<section class="projects-section section" id="proyectos">
  <div class="container">
    <header class="projects-section__header">
      <h2 class="section__title" data-reveal>Proyectos</h2>
      <p class="projects-section__lead" data-reveal>
        Una selección de los proyectos que mejor representan mi trabajo.
      </p>
    </header>
    <div class="projects" data-reveal-stagger>
      {projects.map((project) => (
        <ProjectCard
          title={project.data.title}
          slug={project.id}
          year={project.data.year ?? new Date().getFullYear()}
          summary={project.data.summary}
          thumbnail={{
            full: project.data.cover,
            md: project.data.cover.replace('.webp', '-543.webp'),
            sm: project.data.cover.replace('.webp', '-380.webp'),
          }}
        />
      ))}
    </div>
  </div>
</section>

<style>
  .projects-section__header {
    margin-block-end: 3.5rem;
  }

  .projects-section__lead {
    color: var(--text-muted);
    font-size: 1.6rem;
    margin-block-start: 0.8rem;
  }

  .projects {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }
</style>
