---
import { skills } from '@data/skills'
import TechBadge from '@components/ui/TechBadge.astro'
---

<section class="skills" id="habilidades">
  <div class="skills__container">
    <h2 class="skills__title">Habilidades</h2>
    <div class="skills__list">
      {skills.map((skill) => (
        <TechBadge name={skill.name} techKey={skill.name} />
      ))}
    </div>
  </div>
</section>
