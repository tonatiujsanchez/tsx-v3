<button
  type="button"
  aria-label="Alternar tema claro/oscuro"
  data-theme-toggle
  class="button-change-theme"
>
  <i class="bx bx-sun button-change-theme__icon" aria-hidden="true"></i>
</button>

<script>
  import { initTheme } from '@scripts/theme'
  initTheme()
  document.addEventListener('astro:after-swap', initTheme)
</script>
