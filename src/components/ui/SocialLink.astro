---
interface Props {
  href: string
  label: string
  icon: string
  ariaLabel?: string
}

const { href, label, icon, ariaLabel } = Astro.props
---

<a
  class="social-link"
  href={href}
  aria-label={ariaLabel ?? label}
  target="_blank"
  rel="noopener noreferrer"
>
  <span class="social-link__name">
    <i class={`bx ${icon} social-link__icon`} aria-hidden="true"></i>
    {label}
  </span>
  <i class="bx bx-right-arrow-alt link-external-icon social-link__arrow" aria-hidden="true"></i>
</a>
