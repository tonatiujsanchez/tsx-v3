---
import type { TechName } from '@ptypes/index'
import { getIcon } from '@icons/index'

interface Props {
  techKey: TechName
  size?: number
}

const { techKey, size = 20 } = Astro.props
const slug = getIcon(techKey)
---

<img
  class="tech-icon"
  src={`/icons/${slug}.svg`}
  alt={techKey}
  width={size}
  height={size}
  loading="lazy"
  onerror="this.style.display='none'"
/>

<style>
  .tech-icon {
    display: block;
    border-radius: 0.2rem;
    overflow: hidden;
  }
</style>
