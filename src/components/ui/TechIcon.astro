---
import type { TechName } from '@ptypes/index'
import { getIcon } from '@icons/index'

interface Props {
  techKey: TechName
  size?: number
}

const { techKey, size = 20 } = Astro.props
const slug = getIcon(techKey)
---

<img
  class="tech-icon"
  src={`/icons/${slug}.svg`}
  alt={techKey}
  width={size}
  height={size}
  style={`width: ${size / 10}rem; height: ${size / 10}rem;`}
  loading="lazy"
  onerror="if(this.src.endsWith('.svg')){this.src=this.src.replace('.svg','.webp')}else{this.style.display='none'}"
/>

<style>
  .tech-icon {
    display: block;
    flex-shrink: 0;
    object-fit: contain;
    border-radius: 0.2rem;
  }
</style>
