---
import type { CollectionEntry } from 'astro:content'
import { getCollection, render } from 'astro:content'
import ProjectLayout from '@layouts/ProjectLayout.astro'
import TechIcon from '@components/ui/TechIcon.astro'
import ProjectFigure from '@components/ui/ProjectFigure.astro'
import ProjectContact from '@components/project/ProjectContact.astro'
import { siteConfig } from '@data/site'

export async function getStaticPaths() {
  const projects = await getCollection('projects')
  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }))
}

interface Props {
  project: CollectionEntry<'projects'>
}

const { project } = Astro.props
const { title, description, cover, coverCaption, tech, demo, github, githubFrontend, githubBackend, gallery } =
  project.data
const { Content } = await render(project)

const canonical = `${siteConfig.url}/projects/${project.id}`

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: title,
  description,
  url: canonical,
  image: `${siteConfig.url}${cover}`,
  author: {
    '@type': 'Person',
    name: siteConfig.author,
    url: siteConfig.url,
  },
}
---

<ProjectLayout
  title={`${title} | Tonatiuj Sánchez`}
  description={description}
  canonical={canonical}
  ogImage={cover}
  ogType="article"
  jsonLd={jsonLd}
>
  <main class="container">

    <section class="hero">
      <h1 class="project-title">{title}</h1>
      <p class="project-summary">{description}</p>
      <ProjectFigure
        src={cover}
        alt={`Portada de ${title}`}
        caption={coverCaption}
        transitionName={`project-cover-${project.id}`}
      />
    </section>

    {gallery && gallery.length > 0 && (
      <section class="projects-views">
        {gallery.map((item) => (
          <ProjectFigure
            src={item.src}
            alt={`Vista de ${title}`}
            caption={item.caption}
          />
        ))}
      </section>
    )}

    <section>
      <h2 class="subtitle">Tecnologías utilizadas</h2>
      <div class="technologies">
        {tech.map((t) => (
          <div class="technology">
            <span class="technology__icon">
              <TechIcon techKey={t} size={20} />
            </span>
            <span class="technology__name">{t}</span>
          </div>
        ))}
      </div>
    </section>

    <section class="project-info">
      <div>
        <h2 class="subtitle">Versiones</h2>
        <div class="versions">
          <div class="versions__item">Desktop</div>
          <div class="versions__item">Mobile</div>
        </div>
      </div>

      {(github || githubFrontend || githubBackend || demo) && (
        <div>
          <h2 class="subtitle">Enlaces</h2>
          <div class="links">
            {githubFrontend && (
              <a
                class="links__item"
                href={githubFrontend}
                target="_blank"
                rel="noopener noreferrer"
                aria-label="Ver repositorio frontend del proyecto"
              >
                <span class="links__item-name">
                  <i class="bx bxl-github" aria-hidden="true"></i> Frontend
                </span>
                <i class="bx bx-right-arrow-alt link-external-icon" aria-hidden="true"></i>
              </a>
            )}
            {githubBackend && (
              <a
                class="links__item"
                href={githubBackend}
                target="_blank"
                rel="noopener noreferrer"
                aria-label="Ver repositorio backend del proyecto"
              >
                <span class="links__item-name">
                  <i class="bx bxl-github" aria-hidden="true"></i> Backend
                </span>
                <i class="bx bx-right-arrow-alt link-external-icon" aria-hidden="true"></i>
              </a>
            )}
            {github && (
              <a
                class="links__item"
                href={github}
                target="_blank"
                rel="noopener noreferrer"
                aria-label="Ver repositorio del proyecto"
              >
                <span class="links__item-name">
                  <i class="bx bxl-github" aria-hidden="true"></i> Repositorio
                </span>
                <i class="bx bx-right-arrow-alt link-external-icon" aria-hidden="true"></i>
              </a>
            )}
            {demo && (
              <a
                class="links__item"
                href={demo}
                target="_blank"
                rel="noopener noreferrer"
                aria-label="Ir al proyecto"
              >
                <span class="links__item-name">
                  <i class="bx bx-world" aria-hidden="true"></i> Proyecto
                </span>
                <i class="bx bx-right-arrow-alt link-external-icon" aria-hidden="true"></i>
              </a>
            )}
          </div>
        </div>
      )}
    </section>

    <div class="project-content">
      <Content />
    </div>

    <ProjectContact />

  </main>
</ProjectLayout>

<style>
  .hero {
    padding-block-start: 3rem;
  }

  .project-title {
    color: var(--title-color);
    font-size: 2.5rem;
    margin-block-end: 1.5rem;
  }

  .project-summary {
    color: var(--text-color);
    margin-block-end: 4rem;
  }

  .projects-views {
    margin-block-end: 2rem;
  }

  .subtitle {
    font-size: 1.6rem;
    color: var(--title-color);
    margin-block-end: 2rem;
    font-weight: 500;
  }

  /* ===== Technologies ===== */

  .technologies {
    display: flex;
    gap: 0.8rem;
    flex-wrap: wrap;
    margin-block-end: 4rem;
  }

  .technology {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    border: var(--border-primary);
    border-radius: 2rem;
    padding-block: 0.3rem;
    padding-inline: 1.5rem;
  }

  .technology__icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.2rem;
    height: 2.4rem;
    border-radius: 0.4rem;
    overflow: hidden;
  }

  .technology__name {
    font-size: 1.4rem;
  }

  /* ===== Project info (versions + links) ===== */

  .project-info {
    display: flex;
    flex-wrap: wrap;
    gap: 4rem;
    margin-block-end: 8rem;
  }

  .versions {
    display: flex;
    gap: 1rem;
  }

  .versions__item {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    border: var(--border-primary);
    border-radius: 2rem;
    padding-block: 0.3rem;
    padding-inline: 1.5rem;
  }

  .links {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
  }

  .links__item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding-block: 0.5rem;
    padding-inline: 1.5rem;
    border: var(--border-primary);
    border-radius: 0.5rem;
    transition: all 0.3s;
  }

  .links__item:hover {
    color: var(--title-color);
    border: 0.1rem solid var(--text-color);
  }

  .links__item:hover .link-external-icon {
    animation: float-up 2s ease-in-out infinite;
  }

  .links__item-name {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .links__item-name i {
    font-size: 1.8rem;
  }

  .project-content {
    color: var(--text-color);
    line-height: 1.7;
    margin-block-end: 4rem;
  }

  @media (min-width: 768px) {
    .hero {
      padding-block-start: 9rem;
    }

    .project-info {
      gap: 8rem;
    }
  }
</style>
